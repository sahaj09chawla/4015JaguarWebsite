CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=uploads

# Gmail: use a Google Account with 2-Step Verification and an App Password (not your normal password).
# Paste the 16-character app password with or without spaces — the server strips spaces.
EMAIL_USER=your_sender@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Production: set the same keys in Vercel → Project → Settings → Environment Variables.
PUBLIC_SERVER_URL=https://your-project.vercel.app
VITE_API_BASE_URL=/api
